# Production Environment Variables Template
# Copy this file to .env.production and fill in real values

# REQUIRED: Generate a secure random string (min 32 characters)
# Example: openssl rand -base64 32
JWT_SECRET=CHANGE_THIS_TO_A_SECURE_RANDOM_STRING_MIN_32_CHARS

# MongoDB Connection
MONGO_URI=mongodb://mongo:27017/task_management

# Optional: Redis for rate limiting and session management
# REDIS_URL=redis://redis:6379

# Backend Configuration
NODE_ENV=production
PORT=5000
JWT_EXPIRES_IN=7d
LOG_LEVEL=info

# CORS Configuration
CLIENT_ORIGIN=https://yourdomain.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200

# Frontend Build
VITE_API_BASE_URL=https://yourdomain.com/api/v1
