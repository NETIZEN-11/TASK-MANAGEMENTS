NODE_ENV=development
PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/task_management
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d
CLIENT_ORIGIN=http://localhost:5173
# Comma-separated list of additional trusted origins for production CORS.
# Use this to add new Vercel preview URLs without redeploying the backend.
# Example: ALLOWED_ORIGINS=https://my-preview.vercel.app,https://staging.example.com
ALLOWED_ORIGINS=
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
LOG_LEVEL=info